{
  "name": "bloom",
  "private": true,
  "version": "1.0.0",
  "license": "MIT",
  "author": "Jovan Veljanoski",
  "description": "A calming, touch-friendly contraction timer for pregnancy — real-time duration, intervals, progression trends, and an on-device labor guide. 100% frontend, no server, no tracking.",
  "keywords": [
    "contraction-timer",
    "pregnancy",
    "labor",
    "birth",
    "5-1-1",
    "react",
    "vite",
    "tailwindcss",
    "indexeddb"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/jovanveljanoski/bloom-contraction-tracker.git"
  },
  "homepage": "https://jovanveljanoski.github.io/bloom-contraction-tracker",
  "type": "module",
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "build": "vite build",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "deploy": "npm run build && gh-pages -d dist"
  },
  "dependencies": {
    "@fontsource/figtree": "^5.2.10",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@fontsource/outfit": "^5.2.8",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "vite": "^6.2.3"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.25.0",
    "gh-pages": "^6.3.0",
    "tailwindcss": "^4.1.14",
    "typescript": "~5.8.2"
  }
